# Copie para .env.local (desenvolvimento) e configure no servidor (produção).
# Nenhum valor padrão ou localhost — todas as URLs e dados vêm daqui.

# --- Sessão ---
SESSION_SECRET=
# BOXIFY_SESSION_SECRET=

# --- Site (obrigatório para SEO, Stripe e redirects) ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_URL=

# --- Contato (footer, privacidade, schema) ---
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_ADDRESS=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Redes sociais ---
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_INSTAGRAM_REELS_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
# Conversions API (servidor): token gerado em Eventos > Configurações > API de Conversões.
# Com BOXIFY + lead OK, POST /api/leads envia Lead com o mesmo event_id que o Pixel (deduplicação).
# Nunca exponha este token no cliente; não use prefixo NEXT_PUBLIC_.
FACEBOOK_CAPI_ACCESS_TOKEN=
# Opcional — padrão v21.0 (Graph API).
# META_GRAPH_API_VERSION=v21.0

# --- Boxify (chat flutuante e API) ---
BOXIFY_API_BASE_URL=
BOXIFY_API_TOKEN=
# Leads do formulário são inseridos no pipeline padrão da conta Boxify (não enviamos pipeline_id nem stage_id).
# Chat flutuante: opcionais — se vazios, o componente usa origem e agentId padrão.
NEXT_PUBLIC_BOXIFY_EMBED_ORIGIN=
NEXT_PUBLIC_BOXIFY_AGENT_ID=

# --- Mídia e endereços (home e sobre) ---
NEXT_PUBLIC_VIDEO_HERO_URL=
NEXT_PUBLIC_VIDEO_ESCRITORIO_URL=
NEXT_PUBLIC_MAPS_URL_BELO_HORIZONTE=
NEXT_PUBLIC_MAPS_URL_CUIABA=

# --- Serasa ---
SERASA_API_BASE_URL=
SERASA_TOKEN=

# --- Admin (seed e usuários em lote) ---
ADMIN_SEED_USERNAME=
ADMIN_SEED_PASSWORD=
# Senha inicial dos leads criados em massa ou pelo botão "Adicionar usuário".
# Obrigatória para POST /api/admin/users (importação CSV/XLS e modal).
# Use senha forte; os usuários podem trocar depois em Minha Conta (se houver fluxo).
ADMIN_BULK_DEFAULT_PASSWORD=

# --- E-mail (opcional) — envio automático de senha pelo admin e primeiro acesso / esqueci senha ---
# Resend: https://resend.com — usado em POST .../api/admin/users/[id]/password, primeiro acesso e recuperação de senha.
# Nunca commitar chave real; use só .env.local (gitignored) ou variáveis no painel do host (Vercel etc.).
# RESEND_API_KEY=   # colar chave só no .env.local ou no painel do servidor
# Remetente verificado no Resend (ex.: GT Sette <noreply@seudominio.com>).
# RESEND_FROM=
# Template de recuperação de senha no Resend (default: password-reset-notification). Opcional: UUID publicado.
# RESEND_PASSWORD_RESET_TEMPLATE_ID=password-reset-notification
# Testar conexão (dev): GET http://localhost:3000/api/health/resend — chama API Resend sem enviar e-mail.

# --- WhatsApp (opcional) — envio automático de senha pelo admin ---
# Sem Twilio: o admin informa o número e o sistema abre wa.me com a mensagem (senha) pronta.
# Com Twilio WhatsApp API: mensagem enviada automaticamente.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Remetente sandbox ou número aprovado (ex.: whatsapp:+14155238886).
# TWILIO_WHATSAPP_FROM=
