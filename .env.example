# Copie para .env.local (desenvolvimento) e configure no servidor (produção).
# Nenhum valor padrão ou localhost — todas as URLs e dados vêm daqui.

# --- Sessão ---
SESSION_SECRET=
# BOXIFY_SESSION_SECRET=

# --- Site (obrigatório para SEO, Stripe e redirects) ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_URL=

# --- Contato (footer, privacidade, schema) ---
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_ADDRESS=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Redes sociais ---
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_INSTAGRAM_REELS_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# --- Boxify (chat flutuante e API) ---
BOXIFY_API_BASE_URL=
BOXIFY_API_TOKEN=
# Chat flutuante: opcionais — se vazios, o componente usa origem e agentId padrão.
NEXT_PUBLIC_BOXIFY_EMBED_ORIGIN=
NEXT_PUBLIC_BOXIFY_AGENT_ID=

# --- Mídia e endereços (home e sobre) ---
NEXT_PUBLIC_VIDEO_HERO_URL=
NEXT_PUBLIC_VIDEO_ESCRITORIO_URL=
NEXT_PUBLIC_MAPS_URL_BELO_HORIZONTE=
NEXT_PUBLIC_MAPS_URL_CUIABA=

# --- Serasa ---
SERASA_API_BASE_URL=
SERASA_TOKEN=

# --- Admin (seed e usuários em lote) ---
ADMIN_SEED_USERNAME=
ADMIN_SEED_PASSWORD=
# Senha inicial dos leads criados em massa ou pelo botão "Adicionar usuário".
# Obrigatória para POST /api/admin/users (importação CSV/XLS e modal).
# Use senha forte; os usuários podem trocar depois em Minha Conta (se houver fluxo).
ADMIN_BULK_DEFAULT_PASSWORD=
